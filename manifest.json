{
  "manifest_version": 3,
  "name": "PromptShield",
  "version": "1.0.0",
  "description": "AI Security Firewall — Protect your prompts from data leaks and enforce safe AI agent execution.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "PromptShield — AI Security"
  },
  "background": {
    "service_worker": "sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content/platforms/chatgpt.js", "content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": ["content/platforms/gemini.js", "content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content/platforms/copilot.js", "content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": ["content/platforms/claude.js", "content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://claude.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://customer-proxy.armoriq.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "content/content-style.css"],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://claude.ai/*"
      ]
    }
  ]
}
